@page "/events"
@model SpotOps.Pages.Events.IndexModel

<h2>공연 목록</h2>

@if (!Model.Events.Any())
{
    <p>등록된 공연이 없어요.</p>
}
else
{
    <ul>
        @foreach (var ev in Model.Events)
        {
            <li>
                <a href="/events/@ev.Id">
                    <strong>@ev.Title</strong>
                </a>
                <span>@ev.VenueName</span>
                <span>@ev.EventAt.ToLocalTime().ToString("yyyy.MM.dd HH:mm")</span>
                <span>@ev.Price.ToString("N0")원</span>
                <span>@(ev.TicketType == SpotOps.Models.TicketType.Seated ? "좌석 지정" : "선착순")</span>
            </li>
        }
    </ul>
}