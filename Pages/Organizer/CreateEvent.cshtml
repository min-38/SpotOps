@page "/organizer/create-event"
@model SpotOps.Pages.Organizer.CreateEventModel

<h2>공연 등록</h2>

<form method="post">
    <span asp-validation-summary="All"></span>
    <div>
        <label>공연명</label>
        <input asp-for="Input.Title" />
    </div>
    <div>
        <label>설명</label>
        <textarea asp-for="Input.Description"></textarea>
    </div>
    <div>
        <label>티켓 유형</label>
        <select asp-for="Input.TicketType">
            <option value="Seated">좌석 지정</option>
            <option value="Standing">선착순 입장</option>
        </select>
    </div>
    <div>
        <label>공연 일시</label>
        <input asp-for="Input.EventAt" type="datetime-local" />
    </div>
    <div>
        <label>판매 시작</label>
        <input asp-for="Input.SaleStartAt" type="datetime-local" />
    </div>
    <div>
        <label>판매 종료</label>
        <input asp-for="Input.SaleEndAt" type="datetime-local" />
    </div>
    <div>
        <label>총 수용 인원</label>
        <input asp-for="Input.TotalCapacity" type="number" />
    </div>
    <div>
        <label>가격</label>
        <input asp-for="Input.Price" type="number" step="100" />
    </div>
    <div>
        <label>공연장</label>
        <input asp-for="Input.VenueName" />
    </div>
    <button type="submit">등록하기</button>
</form>