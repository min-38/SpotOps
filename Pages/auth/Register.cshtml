@page
@model SpotOps.Pages.auth.RegisterModel

<h2>회원가입</h2>

<form method="post">
    <div>
        <label>이름</label>
        <input asp-for="Input.Name" />
        <span asp-validation-for="Input.Name"></span>
    </div>
    <div>
        <label>이메일</label>
        <input asp-for="Input.Email" />
        <span asp-validation-for="Input.Email"></span>
    </div>
    <div>
        <label>비밀번호</label>
        <input asp-for="Input.Password" type="password" />
    </div>
    <div>
        <label>전화번호</label>
        <input asp-for="Input.Phone" />
    </div>
    <div>
        <label>가입 유형</label>
        <select asp-for="Input.Role">
            <option value="Buyer">구매자</option>
            <option value="Organizer">주최자</option>
        </select>
    </div>

    <div id="organizer-fields" style="display:none">
        <div>
            <label>사업자번호</label>
            <input asp-for="Input.BusinessNumber" />
        </div>
        <div>
            <label>회사명</label>
            <input asp-for="Input.CompanyName" />
        </div>
    </div>

    <button type="submit">가입하기</button>
</form>

<script>
    const roleSelect = document.querySelector('select[name="Input.Role"]');
    const orgFields = document.getElementById('organizer-fields');

    roleSelect.addEventListener('change', () => {
        orgFields.style.display = roleSelect.value === 'Organizer' ? 'block' : 'none';
    });
</script>