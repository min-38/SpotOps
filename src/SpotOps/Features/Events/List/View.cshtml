@page "/events"
@model SpotOps.Features.Events.List.ViewModel
@{
    ViewData["Title"] = "공연 목록";
}

<h2>공연 목록</h2>

@if (!Model.Events.Any())
{
    <p>등록된 공연이 없어요.</p>
}
else
{
    <ul class="list-unstyled">
        @foreach (var ev in Model.Events)
        {
            <li class="mb-3 border-bottom pb-2">
                <a href="/events/@ev.Id">
                    <strong>@ev.Title</strong>
                </a>
                <div class="small text-muted">
                    <span>@ev.VenueName</span>
                    <span>· @ev.EventAt.ToLocalTime().ToString("yyyy.MM.dd HH:mm")</span>
                    <span>· @(ev.TicketType == SpotOps.Models.TicketType.Seated ? "좌석 지정" : "선착순")</span>
                </div>
            </li>
        }
    </ul>
}
